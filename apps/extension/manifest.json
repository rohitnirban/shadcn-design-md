{
  "manifest_version": 3,
  "name": "shadcn design.md",
  "version": "0.1.0",
  "description": "Export any shadcn preset on ui.shadcn.com/create as a design.md file.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://ui.shadcn.com/create*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
